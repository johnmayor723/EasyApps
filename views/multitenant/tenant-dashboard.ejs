/* Remove default list styling */
.sidebar .menu {
  list-style: none;
  padding: 0;
  margin: 0;
}

/* Remove default li spacing */
.sidebar .menu li {
  margin: 0;
  padding: 0;
}

/* Alternating backgrounds */
.sidebar .menu li:nth-child(odd) {
  background-color: #ffffff;
}

.sidebar .menu li:nth-child(even) {
  background-color: #f5f5f5;
}

/* Menu links styling */
.sidebar .menu li a {
  display: block;
  padding: 14px 20px;
  text-decoration: none;
  color: #333;
  font-weight: 500;
  transition: background 0.2s ease;
}

/* Hover effect */
.sidebar .menu li a:hover {
  background-color: #e9e9e9;
}

/* Add separator line */
.sidebar .menu li {
  border-bottom: 1px solid #e0e0e0;
}

/* Remove border from last item */
.sidebar .menu li:last-child {
  border-bottom: none;
}
.menu i{
margin-right:10px;
width:18px;
text-align:center;
}

.has-sub > a{
display:flex;
justify-content:space-between;
align-items:center;
}

.arrow{
font-size:12px;
opacity:.6;
}

.submenu{
display:none;
list-style:none;
padding-left:28px;
}

.has-sub.active > .submenu{
display:block;
}

.submenu li{
margin:6px 0;
}

/* Analytics pointer style */
.pointer{
border-left:2px solid #ddd;
margin-left:10px;
padding-left:15px;
position:relative;
}

.pointer:before{
content:'';
position:absolute;
top:12px;
left:-2px;
width:12px;
height:2px;
background:#ddd;
}

/* bottom menu */
.menu-bottom{
margin-top:40px;
border-top:1px solid #eee;
padding-top:10px;
}
/* SETTINGS OVERLAY */

.settings-overlay{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,.25);
display:none;
align-items:center;
justify-content:center;
z-index:2000;
}


/* MODAL WINDOW */

.settings-modal{

width:calc(100% - 20px);
height:calc(100% - 20px);

margin:10px;

background:#f8f9fb;
border-radius:10px;

display:flex;
flex-direction:column;

box-shadow:0 20px 50px rgba(0,0,0,.25);

overflow:hidden;

}


/* HEADER */

.settings-header{

background:#fff;
border-bottom:1px solid #ddd;

padding:15px 25px;

display:flex;
justify-content:space-between;
align-items:center;

}

.settings-close{
font-size:22px;
cursor:pointer;
}


/* BODY */

.settings-body{
flex:1;
display:flex;
overflow:hidden;
}


/* SIDEBAR */

.settings-sidebar{

width:240px;
background:#fff;

border-right:1px solid #ddd;

padding:20px;

}

.settings-sidebar ul{
list-style:none;
padding:0;
}

.settings-sidebar li{
margin-bottom:10px;
}

.settings-sidebar a{

display:block;
padding:10px;

border-radius:6px;

text-decoration:none;
color:#333;
font-size:14px;

cursor:pointer;

}

.settings-sidebar a:hover{
background:#f0f0f0;
}

.settings-sidebar i{
margin-right:10px;
}


/* CONTENT */

.settings-content{

flex:1;

padding:40px;

overflow-y:auto;

background:#f8f9fb;

}


/* PANES */

.settings-pane{
display:none;
}

.settings-pane.active{
display:block;
}
   </style>
