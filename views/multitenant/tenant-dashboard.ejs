<script>

function openEditModal(menu)
{
  const modal = document.getElementById("editMenuModal");

  // Set form action dynamically
  document.getElementById("editMenuForm").action =
    "/restaurant-management/menu/" + menu._id + "/edit";

  // Fill fields
  document.getElementById("edit_name").value = menu.name;
  document.getElementById("edit_description").value = menu.description;
  document.getElementById("edit_category").value = menu.category;
  document.getElementById("edit_price").value = menu.price;
  document.getElementById("edit_available").value = menu.available;

  // Image preview
  const img = document.getElementById("edit_image_preview");

  if(menu.image)
  {
    img.src = menu.image;
    img.style.display = "block";
  }
  else
  {
    img.style.display = "none";
  }

  modal.classList.add("active");
}

function closeEditModal()
{
  document.getElementById("editMenuModal")
    .classList.remove("active");
}

</script>
