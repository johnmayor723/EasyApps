<script>

/* Toggle form */
function toggleForm() {
  const container = document.getElementById('menuFormContainer');
  container.style.display =
    container.style.display === 'block' ? 'none' : 'block';
}

/* Load menus dynamically */
document.addEventListener('DOMContentLoaded', async function () {

  const tenantId = "<%= tenant.tenantId %>";

  const tableBody = document.getElementById('menuTableBody');
  const emptyState = document.getElementById('menuEmptyState');
  const tableWrapper = document.getElementById('menuTableWrapper');

  try {

    const response = await fetch('http://easyhostnet.localhost:3000/api/menus/menus-by-tenant', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ tenantId })
    });

    const data = await response.json();
    const menus = data.menus || [];

    if (menus.length === 0) {
      emptyState.style.display = 'block';
      tableWrapper.style.display = 'none';
      return;
    }

    emptyState.style.display = 'none';
    tableWrapper.style.display = 'block';

    menus.forEach(item => {

      const row = document.createElement('tr');

      row.innerHTML = `
        <td>${item.name}</td>
        <td>${item.description}</td>
        <td>${item.price}</td>
        <td>${item.category}</td>
        <td>${item.image ? `<img src="${item.image}" style="width:50px;height:50px;object-fit:cover;border-radius:6px;">` : '—'}</td>
        <td>${item.available ? 'true' : 'false'}</td>
        <td>
          <a href="/restaurant-management/menu/${item._id}/edit" class="btn-edit">Edit</a>
          <a href="/restaurant-management/menu/${item._id}/delete" class="btn-delete">Delete</a>
        </td>
      `;

      tableBody.appendChild(row);

    });

  } catch (err) {
    console.error(err);
  }

});

</script>
<script>
